// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DietaryPreference {
  VEGETARIAN
  NON_VEGETARIAN
  VEGAN
  EGGETARIAN
  OTHER
}

enum HousingPreference {
  SHARED
  PRIVATE_ROOM
  STUDIO
  ONE_BHK
  TWO_BHK
  THREE_BHK_OR_LARGER
  OTHER
}

enum TransportationPreference {
  PUBLIC_TRANSPORT
  TWO_WHEELER
  CAR
  WALKING_CYCLING
  MIXED
  OTHER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile    UserProfile?
  blueprints MigrationBlueprint[]
  journeys   MigrationJourney[]
}

model UserProfile {
  id                       String                    @id @default(uuid())
  userId                   String                    @unique
  occupation               String?
  householdSize            Int                       @default(1)
  numberOfDependents       Int                       @default(0)
  dietaryPreference        DietaryPreference?
  housingPreference        HousingPreference?
  transportationPreference TransportationPreference?
  lifestylePreference      String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model City {
  id        String   @id @default(uuid())
  name      String
  state     String
  country   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  originBlueprints      MigrationBlueprint[] @relation("BlueprintOriginCity")
  destinationBlueprints MigrationBlueprint[] @relation("BlueprintDestinationCity")
  originJourneys        MigrationJourney[]   @relation("JourneyOriginCity")
  destinationJourneys   MigrationJourney[]   @relation("JourneyDestinationCity")

  @@unique([name, state, country])
  @@index([country, state])
}

model MigrationBlueprint {
  id                      String    @id @default(uuid())
  userId                  String
  originCityId            String
  destinationCityId       String
  sourceJourneyId         String?
  expectedMonthlyIncome   Decimal   @db.Decimal(12, 2)
  plannedRelocationDate   DateTime?
  relocatingHouseholdSize Int       @default(1)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  originCity      City              @relation("BlueprintOriginCity", fields: [originCityId], references: [id])
  destinationCity City              @relation("BlueprintDestinationCity", fields: [destinationCityId], references: [id])
  sourceJourney   MigrationJourney? @relation(fields: [sourceJourneyId], references: [id], onDelete: SetNull)
  budget          Budget?

  @@index([userId])
  @@index([originCityId])
  @@index([destinationCityId])
  @@index([sourceJourneyId])
}

model Budget {
  id          String   @id @default(uuid())
  blueprintId String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  blueprint    MigrationBlueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  expenseItems ExpenseItem[]
}

model ExpenseCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenseItems        ExpenseItem[]
  journeyExpenseItems JourneyExpenseItem[]
}

model ExpenseItem {
  id         String   @id @default(uuid())
  budgetId   String
  categoryId String
  amount     Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  budget   Budget          @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  category ExpenseCategory @relation(fields: [categoryId], references: [id])

  @@index([budgetId])
  @@index([categoryId])
}

model MigrationJourney {
  id                       String                    @id @default(uuid())
  userId                   String
  originCityId             String
  destinationCityId        String
  occupation               String?
  householdSize            Int                       @default(1)
  monthlyIncome            Decimal?                  @db.Decimal(12, 2)
  dietaryPreference        DietaryPreference?
  housingPreference        HousingPreference?
  transportationPreference TransportationPreference?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  originCity             City                 @relation("JourneyOriginCity", fields: [originCityId], references: [id])
  destinationCity        City                 @relation("JourneyDestinationCity", fields: [destinationCityId], references: [id])
  expenseItems           JourneyExpenseItem[]
  referencedByBlueprints MigrationBlueprint[]

  @@index([userId])
  @@index([originCityId])
  @@index([destinationCityId])
}

model JourneyExpenseItem {
  id         String   @id @default(uuid())
  journeyId  String
  categoryId String
  amount     Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  journey  MigrationJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  category ExpenseCategory  @relation(fields: [categoryId], references: [id])

  @@index([journeyId])
  @@index([categoryId])
}
